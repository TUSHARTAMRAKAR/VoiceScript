# .gitignore
# ─────────────────────────────────────────────────────────
# Tells Git: "do NOT upload these files to GitHub"
#
# Why? Because:
#   - venv/ has thousands of library files (not our code)
#   - uploads/ has temp audio files (private + pointless)
#   - __pycache__/ is auto-generated Python cache (not needed)
#   - .env has secret keys (never upload secrets!)
# ─────────────────────────────────────────────────────────

# Python virtual environment — huge folder, not our code
venv/
env/
.venv/

# Python cache files — auto-generated, not needed on GitHub
__pycache__/
*.py[cod]
*.pyo

# Temporary audio uploads — private user data
uploads/*.wav
uploads/*.mp3
uploads/*.flac
uploads/*.ogg
# (keep the folder itself using .gitkeep)

# Environment variables file — contains secret API keys
.env
.env.local

# VS Code settings — editor preference, not project code
.vscode/

# OS files — auto-generated by Windows/Mac, useless
.DS_Store
Thumbs.db

# Python egg files
*.egg-info/
dist/
build/
